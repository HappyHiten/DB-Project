<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= event.name %> - Event Details</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <a href="/" class="back-link">← Back to All Events</a>
        
        <div class="event-details">
            <h1><%= event.name %></h1>
            
            <div class="event-info-box">
                <div class="info-row">
                    <span class="info-label">📅 Date:</span>
                    <span class="info-value"><%= new Date(event.event_date).toLocaleDateString() %> at <%= event.event_time %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">📍 Venue:</span>
                    <span class="info-value"><%= event.venue_name || 'TBD' %></span>
                </div>
                <% if (event.venue_address) { %>
                <div class="info-row">
                    <span class="info-label">🏢 Address:</span>
                    <span class="info-value"><%= event.venue_address %></span>
                </div>
                <% } %>
                <div class="info-row">
                    <span class="info-label">🏷️ Category:</span>
                    <span class="info-value"><%= event.category_name || 'Uncategorized' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">👥 Capacity:</span>
                    <span class="info-value"><strong><%= event.current_registrations || 0 %> / <%= event.capacity %></strong></span>
                </div>
                <div class="info-row">
                    <span class="info-label">📝 Description:</span>
                    <span class="info-value"><%= event.description || 'No description provided' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Status:</span>
                    <span class="info-value badge <%= event.status %>"><%= event.status.toUpperCase() %></span>
                </div>
            </div>
            
            <!-- Action Buttons -->
            <div class="action-buttons">
                <a href="/events/<%= event.id %>/edit" class="btn btn-warning">✏️ Edit Event</a>
                <form action="/events/<%= event.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this event? This will remove all registrations.')">
                    <button type="submit" class="btn btn-danger">🗑️ Delete Event</button>
                </form>
            </div>
            
            <!-- Registration Form (INSERT) -->
            <div class="registration-form">
                <h2>Register for this event</h2>
                <% if (event.status === 'closed') { %>
                    <div class="alert alert-warning">⚠️ Registrations are closed for this event.</div>
                <% } else if (event.current_registrations >= event.capacity) { %>
                    <div class="alert alert-danger">❌ This event is full!</div>
                <% } else { %>
                    <form action="/events/<%= event.id %>/register" method="POST">
                        <div class="form-row">
                            <div class="form-group">
                                <input type="text" name="user_name" placeholder="Your Full Name" required>
                            </div>
                            <div class="form-group">
                                <input type="email" name="user_email" placeholder="Your Email Address" required>
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-success">Register Now</button>
                            </div>
                        </div>
                    </form>
                <% } %>
            </div>
            
            <!-- Attendees List (JOIN Operation Result) -->
            <div class="attendees-section">
                <h2>📋 Registered Attendees (<%= attendees.length %>)</h2>
                
                <% if (attendees.length === 0) { %>
                    <div class="alert alert-info">No attendees registered yet. Be the first!</div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="attendees-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>Registered On</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% attendees.forEach(attendee => { %>
                                    <tr>
                                        <td><strong><%= attendee.name %></strong></td>
                                        <td><%= attendee.email %></td>
                                        <td><span class="badge registered"><%= attendee.status %></span></td>
                                        <td><%= new Date(attendee.registration_timestamp).toLocaleString() %></td>
                                        <td>
                                            <form action="/registrations/<%= attendee.registration_id %>/cancel" method="POST" onsubmit="return confirm('Cancel this registration?')">
                                                <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>